# ============================================================
# Supabase Configuration
# Get these from your Supabase project → Settings → API
# ============================================================

# Your Supabase project URL (safe to expose)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anon/public key (safe to expose — protected by RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ============================================================
# NEVER add SUPABASE_SERVICE_ROLE_KEY to the frontend.
# Only use it in trusted server-only contexts if needed.
# ============================================================

# Site URL — used for Open Graph & canonical URLs
NEXT_PUBLIC_SITE_URL=http://localhost:3000
